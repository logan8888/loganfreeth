# Copy this file to .env.local and fill in your keys

# Gelato API
# Get your key from: https://dashboard.gelato.com → Settings → API
GELATO_API_KEY=
# Your Gelato Store ID (found in the store URL on your Gelato dashboard)
GELATO_STORE_ID=

# Printify API
# Get your token from: https://printify.com/app/account/api-access
PRINTIFY_API_KEY=
# Your Printify Shop ID — run the /api/printify-shops debug route to find it
PRINTIFY_SHOP_ID=

# Stripe
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Your domain (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
